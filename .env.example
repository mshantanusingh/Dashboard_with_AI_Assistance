# Unified Campus Intelligence Dashboard — Environment Variables
# Copy this file to .env.local in the frontend directory

# ─── LLM API Configuration ──────────────────────────────────────────────────────
# Choose ONE of the following LLM providers:

# Option 1: Google Gemini (recommended — free tier available)
GEMINI_API_KEY=your_gemini_api_key_here

# Option 2: OpenAI
# OPENAI_API_KEY=your_openai_api_key_here

# ─── MCP Server URLs ────────────────────────────────────────────────────────────
# Default ports for local development
LIBRARY_MCP_URL=http://localhost:8001
CAFETERIA_MCP_URL=http://localhost:8002
EVENTS_MCP_URL=http://localhost:8003
ACADEMICS_MCP_URL=http://localhost:8004
